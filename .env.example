# ===== WhatsApp Cloud API =====
GRAPH_VERSION=v19.0
WHATSAPP_TOKEN=PASTE_TOKEN_HERE
PHONE_NUMBER_ID=PASTE_PHONE_NUMBER_ID_HERE

# Webhook verification (you choose)
VERIFY_TOKEN=matrix_verify_123

# Optional: verify webhook signature (Meta App Secret)
# APP_SECRET=PASTE_APP_SECRET_HERE

# ===== Dashboard Basic Auth =====
DASH_USER=matrix
DASH_PASS=matrix

# ===== Storage paths =====
DATA_DIR=./data
DOWNLOADS_DIR=./downloads

# ===== Media =====
AUTO_DOWNLOAD_MEDIA=true

# ===== AI (optional plugin) =====
AI_MODE=off
# AI_MODE=echo  (demo)
# AI_API_KEY=...
